# ---------------------------------------------------------------------------
# EG Fuel Price Optimisation — local dev env
# ---------------------------------------------------------------------------
# Copy to `.env.local` and fill in. Two ways to reach the Lakebase instance
# `eg-fuel-pricing`:
#
#   Mode A (recommended): use your Databricks CLI profile; the SDK mints a
#   short-lived OAuth credential per connection for the database instance.
#     EG_DATABRICKS_HOST=https://fe-vm-alice.cloud.databricks.com
#     DATABRICKS_PROFILE=alice
#     EG_LAKEBASE_INSTANCE=eg-fuel-pricing
#     PGHOST=ep-nameless-tooth-d2gveqy4.database.us-east-1.cloud.databricks.com
#     PGDATABASE=databricks_postgres
#
#   Mode B: a static Postgres connection string (e.g. a one-off credential).
#   Handy for seeding / building the UI without the SDK in the loop.
#     EG_LAKEBASE_URL=postgresql://user:token@host:5432/databricks_postgres?sslmode=require

EG_DATABRICKS_HOST=https://fe-vm-alice.cloud.databricks.com
DATABRICKS_PROFILE=alice

EG_LAKEBASE_INSTANCE=eg-fuel-pricing
PGHOST=ep-nameless-tooth-d2gveqy4.database.us-east-1.cloud.databricks.com
PGDATABASE=databricks_postgres
EG_PG_APP_SCHEMA=eg_app

# Mode B alternative (uncomment to use a static URL instead of SDK OAuth):
# EG_LAKEBASE_URL=postgresql://USER:TOKEN@ep-nameless-tooth-d2gveqy4.database.us-east-1.cloud.databricks.com:5432/databricks_postgres?sslmode=require

# Model Serving endpoints (foundation model APIs)
EG_LLM_ENDPOINT=serving-endpoints/databricks-claude-sonnet-4-6/invocations
EG_LLM_FAST_ENDPOINT=serving-endpoints/databricks-claude-haiku-4-5/invocations

# Auth for Model Serving + warehouse (local dev). Prefer OAuth client creds in
# deployment; locally a PAT is simplest:
# DATABRICKS_TOKEN=dapi...
